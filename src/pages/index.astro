---
import '../styles/landing.css';
import { tabs } from '../data/navigation.mjs';

const testimonials_row1 = [
  { user: 'therno', quote: '"它在运营我的公司。"' },
  { user: 'karpathy', quote: '"阅读体验很棒，谢谢。喜欢 Oracle 和 Claw。"' },
  { user: 'davemorin', quote: '"我甚至不知道该怎么称呼 OpenClaw。这是全新的事物。用了几周后，这是自 ChatGPT 发布以来，我第一次感觉自己活在未来。"' },
  { user: 'crossiBuilds', quote: '"Siri 本该成为的样子。而且远不止于此。"' },
  { user: 'KrauseFx', quote: '"@steipete 用 OpenClaw 做出的东西超乎想象。"' },
  { user: 'Hesamation', quote: '"开源社区造了一个比 Siri 更好的版本，而 Apple 在这上面躺了好几年。"' },
  { user: 'nofil_ai', quote: '"OpenClaw 就是 Jarvis。它已经存在了。"' },
  { user: 'cnakazawa', quote: '"OpenClaw 是很久以来第一个让我不断去 GitHub 查看新版本的\u2018软件\u2019。难以言表。"' },
];
const testimonials_row2 = [
  { user: 'tobi_bsf', quote: '"用了 OpenClaw 一周，真的感觉像早期 AGI。"' },
  { user: 'Dimillian', quote: '"Anthropic 或 OpenAI 这样的巨头造不出这个。大公司的运作方式不可能做到。"' },
  { user: 'lycfyi', quote: '"AI 是队友，不是工具。数字员工的终局已经到来。"' },
  { user: 'snopoke', quote: '"感觉就像 20 年前用 Linux 对比 Windows —— 你掌控一切。"' },
  { user: 'conradsagewiz', quote: '"遛狗时用手机通过 Telegram 让它在电脑上用 Codex CLI 创建规格文件。"' },
  { user: 'dreetje', quote: '"我对 OpenClaw 上瘾了。它已经成为我日常生活不可或缺的部分。"' },
  { user: 'danpeguine', quote: '"你的上下文和技能存在你自己的电脑上。它是公司助手、家庭助手、团队工具。"' },
  { user: 'robmartinson', quote: '"太疯狂了。OpenClaw 是超能力。"' },
];

const sponsors = [
  { name: 'OpenAI', logo: '/assets/sponsors/openai.svg', url: 'https://openai.com', cls: 'invert-on-light' },
  { name: 'Vercel', logoDark: '/assets/sponsors/vercel.svg', logoLight: '/assets/sponsors/vercel.svg', url: 'https://vercel.com', cls: 'invert-on-light' },
  { name: 'Blacksmith', logo: '/assets/sponsors/blacksmith.svg', url: 'https://blacksmith.sh', cls: 'invert-on-light' },
  { name: 'Convex', logo: '/assets/sponsors/convex.svg', url: 'https://www.convex.dev', cls: 'invert-on-light' },
];
---

<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title>OpenClaw 中文网 — 真正能做事的开源 AI 助手</title>
  <meta name="description" content="OpenClaw 是开源自托管的个人 AI 智能体，支持 WhatsApp、Telegram、Discord、飞书、钉钉、企业微信等 20+ 聊天平台。" />
  <link rel="icon" href="/assets/pixel-lobster.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700&family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  <script is:inline>
    (() => {
      const key = 'starlight-theme';
      const saved = localStorage.getItem(key);
      const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = theme;
    })();
  </script>
</head>
<body>

<!-- Site Header -->
<header class="oc-site-header">
  <div class="oc-header-bar">
    <a href="/" class="oc-header-logo" aria-label="OpenClaw 中文网首页">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
        <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="#ff4d4d"/>
        <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="#ff4d4d"/>
        <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="#ff4d4d"/>
        <circle cx="45" cy="35" r="6" fill="#050810"/>
        <circle cx="75" cy="35" r="6" fill="#050810"/>
        <circle cx="46" cy="34" r="2" fill="#00e5cc"/>
        <circle cx="76" cy="34" r="2" fill="#00e5cc"/>
      </svg>
    </a>

    <div class="oc-header-search" id="header-search" role="button" tabindex="0" aria-label="搜索文档">
      <svg class="oc-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span class="oc-search-placeholder">Search ...</span>
      <kbd class="oc-search-kbd">⌘K</kbd>
    </div>

    <nav class="oc-header-links">
      <div class="oc-qr-wrap">
        <button type="button" class="oc-header-link oc-qr-trigger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>OpenClaw交流群</span>
        </button>
        <div class="oc-qr-popup">
          <img src="/assets/openclaw-wechat-qr.png" alt="OpenClaw 交流群二维码" width="240" height="240" />
        </div>
      </div>
      <a href="https://ai.codefather.cn" target="_blank" rel="noopener noreferrer" class="oc-header-link">
        <img src="https://www.codefather.cn/logo.png" alt="" width="20" height="20" class="oc-header-link-icon" loading="lazy"/>
        <span>鱼皮AI导航</span>
      </a>
      <a href="https://github.com/openclaw/openclaw" target="_blank" rel="noopener noreferrer" class="oc-header-link">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <button class="oc-header-theme-btn" type="button" id="theme-toggle" aria-label="切换颜色主题">
        <span id="theme-icon" aria-hidden="true"></span>
      </button>
    </nav>
  </div>

  <nav class="oc-header-tabs">
    <div class="oc-header-tabs-inner">
      {tabs.map((tab) => (
        <a class="oc-header-tab" href={tab.firstPage}>{tab.label}</a>
      ))}
    </div>
  </nav>
</header>

<!-- Background layers -->
<div class="oc-stars"></div>
<div class="oc-nebula"></div>

<main class="oc-container">

  <!-- Hero -->
  <header class="oc-hero">
    <div class="oc-lobster-icon" aria-hidden="true">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="url(#lobster-gradient)" class="claw-body" />
        <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="url(#lobster-gradient)" class="claw-left" />
        <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="url(#lobster-gradient)" class="claw-right" />
        <path d="M45 15 Q35 5 30 8" stroke="var(--coral-bright)" stroke-width="2" stroke-linecap="round" class="antenna" />
        <path d="M75 15 Q85 5 90 8" stroke="var(--coral-bright)" stroke-width="2" stroke-linecap="round" class="antenna" />
        <circle cx="45" cy="35" r="6" fill="#050810" class="eye" />
        <circle cx="75" cy="35" r="6" fill="#050810" class="eye" />
        <circle cx="46" cy="34" r="2" fill="#00e5cc" class="eye-glow" />
        <circle cx="76" cy="34" r="2" fill="#00e5cc" class="eye-glow" />
        <defs>
          <linearGradient id="lobster-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="var(--logo-gradient-start)" />
            <stop offset="100%" stop-color="var(--logo-gradient-end)" />
          </linearGradient>
        </defs>
      </svg>
    </div>
    <h1 class="oc-title">
      <span class="oc-title-main">OpenClaw 中文网</span>
    </h1>
    <p class="oc-tagline">The AI that actually does things.</p>
    <p class="oc-description">
      清理收件箱、发送邮件、管理日历、自动值机。<br />
      通过 WhatsApp、Telegram 或任何你已经在用的聊天应用。
    </p>
  </header>

  <!-- Latest Post -->
  <section class="oc-latest-post">
    <a href="https://openclaw.ai/blog/virustotal-partnership" target="_blank" rel="noopener noreferrer" class="oc-latest-post-card">
      <span class="oc-latest-post-badge">New</span>
      <span class="oc-latest-post-title">OpenClaw 与 VirusTotal 合作保障 Skill 安全</span>
      <span class="oc-latest-post-link">→</span>
    </a>
  </section>

  <!-- Testimonials -->
  <section class="oc-testimonials">
    <div class="oc-section-header">
      <h2 class="oc-section-title"><span class="oc-accent">⟩</span> 用户评价</h2>
      <a href="https://openclaw.ai/shoutouts" target="_blank" rel="noopener noreferrer" class="oc-section-link">查看全部 →</a>
    </div>
    <div class="oc-testimonials-track">
      <div class="oc-testimonials-row oc-row-1">
        {[...testimonials_row1, ...testimonials_row1].map(t => (
          <div class="oc-testimonial-card">
            <img src={`https://unavatar.io/x/${t.user}`} alt={t.user} class="oc-testimonial-avatar" loading="lazy" />
            <div class="oc-testimonial-content">
              <p class="oc-testimonial-quote">{t.quote}</p>
              <span class="oc-testimonial-author">@{t.user}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="oc-testimonials-row oc-row-2">
        {[...testimonials_row2, ...testimonials_row2].map(t => (
          <div class="oc-testimonial-card">
            <img src={`https://unavatar.io/x/${t.user}`} alt={t.user} class="oc-testimonial-avatar" loading="lazy" />
            <div class="oc-testimonial-content">
              <p class="oc-testimonial-quote">{t.quote}</p>
              <span class="oc-testimonial-author">@{t.user}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="oc-quickstart">
    <div class="oc-section-header">
      <h2 class="oc-section-title"><span class="oc-accent">⟩</span> 快速开始</h2>
    </div>
    <div class="oc-code-block">
      <div class="oc-code-header">
        <span class="oc-code-dot"></span>
        <span class="oc-code-dot"></span>
        <span class="oc-code-dot"></span>
        <div class="oc-mode-switch">
          <button class="oc-mode-btn active" data-mode="oneliner">一键安装</button>
          <button class="oc-mode-btn" data-mode="npm">npm</button>
          <button class="oc-mode-btn" data-mode="hackable">Hackable</button>
          <button class="oc-mode-btn" data-mode="macos">macOS</button>
        </div>
        <div class="oc-pm-switch" id="pm-switch" style="display:none;">
          <button class="oc-pm-btn active" data-pm="npm">npm</button>
          <button class="oc-pm-btn" data-pm="pnpm">pnpm</button>
        </div>
        <div class="oc-hackable-switch" id="hackable-switch" style="display:none;">
          <button class="oc-hackable-btn active" data-hackable="installer">installer</button>
          <button class="oc-hackable-btn" data-hackable="pnpm">pnpm</button>
        </div>
        <div class="oc-os-switch" id="os-switch">
          <button class="oc-os-btn active" data-os="unix">macOS/Linux</button>
          <button class="oc-os-btn" data-os="windows">Windows</button>
        </div>
        <div class="oc-beta-switch" id="beta-switch">
          <button class="oc-beta-btn" id="beta-btn" data-beta="false">
            <span class="oc-beta-label">β</span>
            <span class="oc-beta-text">Beta</span>
          </button>
        </div>
      </div>

      <!-- One-liner -->
      <div id="code-oneliner" class="oc-code-content">
        <div class="oc-code-line comment" id="oneliner-comment"># 适用于所有平台。macOS 首次运行可能需要管理员权限安装 Homebrew。</div>
        <div class="oc-code-line cmd">
          <span class="oc-code-prompt">$</span>
          <span class="oc-code-cmd" id="oneliner-cmd">curl -fsSL https://openclaw.ai/install.sh | bash</span>
          <button class="oc-copy-btn" data-cmd="curl -fsSL https://openclaw.ai/install.sh | bash" title="复制">
            <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

      <!-- npm -->
      <div id="code-npm" class="oc-code-content" style="display:none;">
        <div class="oc-code-line comment"># 安装 OpenClaw</div>
        <div class="oc-code-line cmd">
          <span class="oc-code-prompt">$</span>
          <span class="oc-code-cmd" id="npm-install-cmd">npm i -g openclaw</span>
          <button class="oc-copy-btn" data-cmd="npm i -g openclaw" title="复制">
            <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
        <div class="oc-code-line comment"># 开始使用</div>
        <div class="oc-code-line cmd">
          <span class="oc-code-prompt">$</span>
          <span class="oc-code-cmd">openclaw onboard</span>
          <button class="oc-copy-btn" data-cmd="openclaw onboard" title="复制">
            <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Hackable -->
      <div id="code-hackable" class="oc-code-content" style="display:none;">
        <div class="oc-code-line comment" id="hackable-comment"># 给喜欢读源码的你</div>
        <div class="oc-code-line cmd" id="hackable-line1">
          <span class="oc-code-prompt">$</span>
          <span class="oc-code-cmd" id="hackable-cmd1">curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git</span>
          <button class="oc-copy-btn" data-cmd="curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git" title="复制">
            <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

      <!-- macOS App -->
      <div id="code-macos" class="oc-code-content" style="display:none;">
        <div class="oc-macos-app">
          <div>
            <div class="oc-macos-tagline">配套应用（Beta）</div>
            <div class="oc-macos-subtitle">菜单栏快捷访问你的龙虾。与 CLI 完美搭配。</div>
          </div>
          <a href="https://github.com/openclaw/openclaw/releases/latest" target="_blank" rel="noopener" class="oc-macos-download-btn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            下载 macOS 版
          </a>
          <div class="oc-macos-meta">需要 macOS 15+ · Universal Binary</div>
        </div>
      </div>
    </div>
    <p class="oc-quickstart-note">适用于 macOS、Windows 和 Linux。一键安装会自动安装 Node.js 和所有依赖。</p>
  </section>

  <!-- Features -->
  <section class="oc-features">
    <div class="oc-section-header">
      <h2 class="oc-section-title"><span class="oc-accent">⟩</span> 核心功能</h2>
    </div>
    <div class="oc-features-grid">
      <a class="oc-feature-card" href="/start/getting-started">
        <div class="oc-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--coral-bright)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div>
        <h3 class="oc-feature-title">运行在你的电脑上</h3>
        <p class="oc-feature-desc">Mac、Windows 或 Linux。Anthropic、OpenAI 或本地模型。默认私有 —— 你的数据只属于你。</p>
      </a>
      <a class="oc-feature-card" href="/channels">
        <div class="oc-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--coral-bright)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/></svg></div>
        <h3 class="oc-feature-title">支持所有聊天应用</h3>
        <p class="oc-feature-desc">WhatsApp、Telegram、Discord、Slack、Signal 或 iMessage。私聊和群聊都能用。</p>
      </a>
      <a class="oc-feature-card" href="/concepts/memory">
        <div class="oc-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--coral-bright)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18V5"/><path d="M15 13a4.17 4.17 0 0 1-3-4 4.17 4.17 0 0 1-3 4"/><path d="M17.598 6.5A3 3 0 1 0 12 5a3 3 0 1 0-5.598 1.5"/><path d="M17.997 5.125a4 4 0 0 1 2.526 5.77"/><path d="M18 18a4 4 0 0 0 2-7.464"/><path d="M19.967 17.483A4 4 0 1 1 12 18a4 4 0 1 1-7.967-.517"/><path d="M6 18a4 4 0 0 1-2-7.464"/><path d="M6.003 5.125a4 4 0 0 0-2.526 5.77"/></svg></div>
        <h3 class="oc-feature-title">持久记忆</h3>
        <p class="oc-feature-desc">记住你，成为独一无二属于你的 AI。你的偏好、你的上下文、你的助手。</p>
      </a>
      <a class="oc-feature-card" href="/tools/browser">
