<script is:inline>
// Theme toggle
(() => {
  const KEY = 'starlight-theme';
  const btn = document.getElementById('theme-toggle');
  const icon = document.getElementById('theme-icon');

  function getTheme() {
    return document.documentElement.dataset.theme || 'dark';
  }
  function applyIcon() {
    icon.textContent = getTheme() === 'dark' ? '☀️' : '🌙';
  }
  applyIcon();

  btn.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    document.documentElement.style.colorScheme = next;
    localStorage.setItem(KEY, next);
    applyIcon();
  });
})();

// Search bar -> jump to docs
(() => {
  const searchEl = document.getElementById('header-search');
  if (searchEl) {
    searchEl.addEventListener('click', () => {
      window.location.href = '/docs-home';
    });
    searchEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        window.location.href = '/docs-home';
      }
    });
  }
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      window.location.href = '/docs-home';
    }
  });
})();

// QuickStart tab switching
(() => {
  const modes = document.querySelectorAll('.oc-mode-btn');
  const panels = {
    oneliner: document.getElementById('code-oneliner'),
    npm: document.getElementById('code-npm'),
    hackable: document.getElementById('code-hackable'),
    macos: document.getElementById('code-macos'),
  };
  const pmSwitch = document.getElementById('pm-switch');
  const osSwitch = document.getElementById('os-switch');
  const hackableSwitch = document.getElementById('hackable-switch');
  const betaSwitch = document.getElementById('beta-switch');

  function showMode(mode) {
    Object.values(panels).forEach(p => { if (p) p.style.display = 'none'; });
    if (panels[mode]) panels[mode].style.display = '';
    modes.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));

    pmSwitch.style.display = mode === 'npm' ? '' : 'none';
    osSwitch.style.display = mode === 'oneliner' ? '' : 'none';
    hackableSwitch.style.display = mode === 'hackable' ? '' : 'none';
    betaSwitch.style.display = (mode === 'macos') ? 'none' : '';
  }

  modes.forEach(btn => {
    btn.addEventListener('click', () => showMode(btn.dataset.mode));
  });

  // PM switch
  document.querySelectorAll('.oc-pm-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oc-pm-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      refreshCommands();
    });
  });

  // OS switch
  document.querySelectorAll('.oc-os-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oc-os-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const commentEl = document.getElementById('oneliner-comment');
      if (btn.dataset.os === 'windows') {
        commentEl.textContent = '# Windows (PowerShell，以管理员身份运行)';
      } else {
        commentEl.textContent = '# 适用于所有平台。macOS 首次运行可能需要管理员权限安装 Homebrew。';
      }
      refreshCommands();
    });
  });

  // Hackable switch
  document.querySelectorAll('.oc-hackable-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.oc-hackable-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const commentEl = document.getElementById('hackable-comment');
      if (btn.dataset.hackable === 'pnpm') {
        commentEl.textContent = '# 你显然知道自己在做什么';
      } else {
        commentEl.textContent = '# 给喜欢读源码的你';
      }
      refreshCommands();
    });
  });

  // Beta toggle
  const betaBtn = document.getElementById('beta-btn');
  const betaCommands = {
    oneliner: {
      unix:    { stable: 'curl -fsSL https://openclaw.ai/install.sh | bash', beta: 'curl -fsSL https://openclaw.ai/install.sh | bash -s -- --beta' },
      windows: { stable: 'irm https://openclaw.ai/install.ps1 | iex', beta: 'irm https://openclaw.ai/install.ps1 | iex -beta' },
    },
    npm: {
      npm:  { install_stable: 'npm i -g openclaw',  install_beta: 'npm i -g openclaw@beta' },
      pnpm: { install_stable: 'pnpm add -g openclaw', install_beta: 'pnpm add -g openclaw@beta' },
    },
    hackable: {
      installer: { stable: 'curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git', beta: 'curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git --beta' },
      pnpm:      { stable: 'git clone https://github.com/openclaw/openclaw.git && cd openclaw && pnpm install && pnpm run build', beta: 'git clone -b beta https://github.com/openclaw/openclaw.git && cd openclaw && pnpm install && pnpm run build' },
    },
  };

  function isBeta() { return betaBtn && betaBtn.dataset.beta === 'true'; }

  function getActiveMode() {
    const activeMode = document.querySelector('.oc-mode-btn.active');
    return activeMode ? activeMode.dataset.mode : 'oneliner';
  }

  function refreshCommands() {
    const beta = isBeta();
    const mode = getActiveMode();

    // Oneliner
    const osBtn = document.querySelector('.oc-os-btn.active');
    const os = osBtn ? osBtn.dataset.os : 'unix';
    const onelinerCmd = document.getElementById('oneliner-cmd');
    if (onelinerCmd) {
      const val = beta ? betaCommands.oneliner[os].beta : betaCommands.oneliner[os].stable;
      onelinerCmd.textContent = val;
      onelinerCmd.closest('.oc-code-line')?.querySelector('.oc-copy-btn')?.setAttribute('data-cmd', val);
    }

    // npm
    const pmBtn = document.querySelector('.oc-pm-btn.active');
    const pm = pmBtn ? pmBtn.dataset.pm : 'npm';
    const npmInstallCmd = document.getElementById('npm-install-cmd');
    if (npmInstallCmd) {
      const val = beta ? betaCommands.npm[pm].install_beta : betaCommands.npm[pm].install_stable;
      npmInstallCmd.textContent = val;
      npmInstallCmd.closest('.oc-code-line')?.querySelector('.oc-copy-btn')?.setAttribute('data-cmd', val);
    }

    // Hackable
    const hackBtn = document.querySelector('.oc-hackable-btn.active');
    const hack = hackBtn ? hackBtn.dataset.hackable : 'installer';
    const hackableCmd = document.getElementById('hackable-cmd1');
    if (hackableCmd) {
      const val = beta ? betaCommands.hackable[hack].beta : betaCommands.hackable[hack].stable;
      hackableCmd.textContent = val;
      hackableCmd.closest('.oc-code-line')?.querySelector('.oc-copy-btn')?.setAttribute('data-cmd', val);
    }
  }

  if (betaBtn) {
    betaBtn.addEventListener('click', () => {
      const active = betaBtn.dataset.beta === 'true';
      betaBtn.dataset.beta = active ? 'false' : 'true';
      betaBtn.classList.toggle('active', !active);
      refreshCommands();
    });
  }

  // Copy buttons
  document.querySelectorAll('.oc-copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const cmd = btn.dataset.cmd || btn.previousElementSibling?.textContent || '';
      await navigator.clipboard.writeText(cmd.trim());
      btn.classList.add('copied');
      const copyIcon = btn.querySelector('.copy-icon');
      const checkIcon = btn.querySelector('.check-icon');
      if (copyIcon) copyIcon.style.display = 'none';
      if (checkIcon) checkIcon.style.display = '';
      setTimeout(() => {
        btn.classList.remove('copied');
        if (copyIcon) copyIcon.style.display = '';
        if (checkIcon) checkIcon.style.display = 'none';
      }, 2000);
    });
  });
})();
</script>

